root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,vue,css,scss,html,json}]
indent_style = space
indent_size = 2

[*.{java,kt,groovy}]
indent_style = space
indent_size = 4

[*.{xml,yml,yaml}]
indent_style = space
indent_size = 2

[*.{properties,sql}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false